# Configuração de Ambiente - Airflow com BigQuery Medallion Architecture
# Copy this file to .env and update with your values

# ====================
# Google Cloud Platform
# ====================
GCP_PROJECT_ID=seu-projeto-gcp
GCP_REGION=us-central1

# Credenciais do GCP (caminho para arquivo JSON)
# Você pode usar este arquivo ou configurar via Application Default Credentials
GOOGLE_APPLICATION_CREDENTIALS=/opt/airflow/gcp-key.json

# ====================
# Airflow
# ====================
# Ambiente
AIRFLOW_ENV=dev  # dev, staging, prod

# Variáveis do Airflow
AIRFLOW__CORE__DAGS_FOLDER=./dags
AIRFLOW__CORE__PLUGINS_FOLDER=./plugins
AIRFLOW__CORE__BASE_LOG_FOLDER=./logs
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW_UID=50000
AIRFLOW__WEBSERVER__BASE_URL=http://localhost:8080

# Conectividade
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__SQL_ALCHEMY_CONN=sqlite:////tmp/airflow.db

# ====================
# BigQuery
# ====================
BIGQUERY_DATASET_PREFIX=dev  # dev, staging, prod
BIGQUERY_LOCATION=US
BIGQUERY_CONN_ID=google_cloud_default

# ====================
# API Externas (Exemplo)
# ====================
# Credenciais para APIs externas
API_BASE_URL=https://api.example.com
API_KEY=your-api-key-here
API_SECRET=your-api-secret-here
API_TIMEOUT=30

# ====================
# Logging e Monitoramento
# ====================
LOG_LEVEL=INFO
SLACK_WEBHOOK_URL=  # Para alertas no Slack (opcional)
EMAIL_ALERT=False

# ====================
# Desenvolvimento
# ====================
# Debug mode
DEBUG=False

# PostgreSQL local (se usar LocalExecutor com meta DB)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
